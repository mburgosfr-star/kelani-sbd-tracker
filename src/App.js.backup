import React, { useState, useEffect, useRef } from 'react';
import { LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer } from 'recharts';

const ACCESSORIES = {
  Squat: [
    { name: 'Romanian Deadlift', sets: 3, reps: 10, weight: 60 },
    { name: 'Leg Press', sets: 3, reps: 12, weight: 100 },
  ],
  Bench: [
    { name: 'Triceps Pushdown', sets: 3, reps: 12, weight: 30 },
    { name: 'Dumbbell Row', sets: 3, reps: 10, weight: 25 },
  ],
  Deadlift: [
    { name: 'Good Morning', sets: 3, reps: 10, weight: 40 },
    { name: 'Pull-ups', sets: 3, reps: 8, weight: 0 },
  ],
};

function getRestTime(reps) {
  if (reps <= 5) return 300;
  if (reps <= 10) return 180;
  return 90;
}

function epley(weight, reps) {
  if (reps === 1) return weight;
  return Math.round(weight * (1 + reps / 30));
}

function generateWarmups(firstWorkWeight) {
  const warmups = [];
  let w = 20;
  while (true) {
    if (firstWorkWeight - w >= 25) {
      warmups.push({ weight: w, reps: 5, isWarmup: true, done: false });
      w += 50;
    } else {
      break;
    }
  }
  return warmups;
}

function generateProgram(s, b, d, accessoryPRs = {}) {
  function round25(w) { return Math.round(w / 2.5) * 2.5; }
  const rotation = [
    { cycle: 1, squat: 'heavy', bench: 'explosive', deadlift: 'rep' },
    { cycle: 1, squat: 'rep',   bench: 'heavy',     deadlift: 'explosive' },
    { cycle: 1, squat: 'explosive', bench: 'rep',   deadlift: 'heavy' },
    { cycle: 2, squat: 'heavy', bench: 'explosive', deadlift: 'rep' },
    { cycle: 2, squat: 'rep',   bench: 'heavy',     deadlift: 'explosive' },
    { cycle: 2, squat: 'explosive', bench: 'rep',   deadlift: 'heavy' },
    { cycle: 3, squat: 'heavy', bench: 'explosive', deadlift: 'rep' },
    { cycle: 3, squat: 'rep',   bench: 'heavy',     deadlift: 'explosive' },
    { cycle: 3, squat: 'explosive', bench: 'rep',   deadlift: 'heavy' },
  ];
  function getSets(mode, cycle, oneRM) {
    if (mode === 'heavy') {
      const topPct  = cycle === 1 ? 0.875 : cycle === 2 ? 0.90 : 0.925;
      const topReps = cycle === 1 ? 3 : cycle === 2 ? 2 : 1;
      return [
        { reps: 5, pct: 0.50, weight: round25(oneRM * 0.50) },
        { reps: 4, pct: 0.60, weight: round25(oneRM * 0.60) },
        { reps: 3, pct: 0.70, weight: round25(oneRM * 0.70) },
        { reps: 2, pct: 0.80, weight: round25(oneRM * 0.80) },
        { reps: topReps, pct: topPct, weight: round25(oneRM * topPct) },
      ];
    }
    if (mode === 'explosive') {
      return Array(8).fill(null).map(() => ({ reps: 2, pct: 0.60, weight: round25(oneRM * 0.60) }));
    }
    if (mode === 'rep') {
      const pct = cycle === 1 ? 0.65 : cycle === 2 ? 0.70 : 0.75;
      return Array(3).fill(null).map(() => ({ reps: 8, pct, weight: round25(oneRM * pct) }));
    }
  }
  const workouts = [];
  let num = 1;
  rotation.forEach(week => {
    [['Squat', week.squat, s], ['Bench', week.bench, b], ['Deadlift', week.deadlift, d]].forEach(([lift, mode, oneRM]) => {
      const sets = getSets(mode, week.cycle, oneRM).map(set => ({ ...set, done: false }));
      const warmups = generateWarmups(sets[0].weight);
      workouts.push({
        number: num++, type: 'training', cycle: week.cycle, lift, mode,
        warmups,
        sets,
        accessories: ACCESSORIES[lift].map(a => ({
          ...a,
          weight: accessoryPRs[a.name] || a.weight,
          done: Array(a.sets).fill(false),
          weights: Array(a.sets).fill(accessoryPRs[a.name] || a.weight),
        })),
      });
    });
  });
  ['Squat', 'Bench', 'Deadlift'].forEach((lift, i) => {
    const oneRM = [s, b, d][i];
    workouts.push({
      number: num++, type: 'peak', lift, mode: 'peak',
      warmups: [],
      sets: [
        { reps: 1, pct: 0.90, weight: round25(oneRM * 0.90), label: 'Opener', done: false },
        { reps: 1, pct: 0.95, weight: round25(oneRM * 0.95), label: 'Tweede poging', done: false },
      ],
      accessories: [],
    });
  });
  ['Squat', 'Bench', 'Deadlift'].forEach((lift, i) => {
    const oneRM = [s, b, d][i];
    workouts.push({
      number: num++, type: 'peak', lift, mode: 'peak',
      warmups: [],
      sets: [{ reps: 1, pct: 1.00, weight: round25(oneRM * 1.00), label: 'Max poging', done: false }],
      accessories: [],
    });
  });
  workouts.push({ number: num++, type: 'rest', lift: null, mode: null, warmups: [], sets: [], accessories: [] });
  return workouts;
}

const MODE_LABEL = { heavy: 'Zwaar', explosive: 'Explosief', rep: 'Repetitie', peak: 'Peak' };
const MODE_COLOR = { heavy: '#e67e22', explosive: '#27ae60', rep: '#2980b9', peak: '#8e44ad' };
const HEADER_COLOR = { 1: '#2c3e50', 2: '#1a5276', 3: '#154360', peak: '#8e44ad', rest: '#95a5a6' };

function RestTimer({ seconds, onDismiss }) {
  const [remaining, setRemaining] = useState(seconds);
  const intervalRef = useRef(null);
  const hasBeepedRef = useRef(false);
  useEffect(() => { setRemaining(seconds); hasBeepedRef.current = false; }, [seconds]);
  useEffect(() => {
    if (remaining <= 0) {
      clearInterval(intervalRef.current);
      if (!hasBeepedRef.current) { hasBeepedRef.current = true; playBeep(); }
      return;
    }
    intervalRef.current = setInterval(() => setRemaining(r => r - 1), 1000);
    return () => clearInterval(intervalRef.current);
  }, [remaining, seconds]);
  function playBeep() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      [0, 0.3, 0.6].forEach(delay => {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.value = 880;
        osc.type = 'sine';
        gain.gain.setValueAtTime(0.5, ctx.currentTime + delay);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + delay + 0.3);
        osc.start(ctx.currentTime + delay);
        osc.stop(ctx.currentTime + delay + 0.3);
      });
    } catch(e) {}
  }
  const mins = Math.floor(remaining / 60);
  const secs = remaining % 60;
  const pct = remaining / seconds;
  const radius = 54;
  const circumference = 2 * Math.PI * radius;
  const isDone = remaining <= 0;
  return (
    <div style={{ position: 'fixed', bottom: 0, left: 0, right: 0, background: 'white', borderTop: '1px solid #ddd', padding: '16px 24px', display: 'flex', alignItems: 'center', justifyContent: 'space-between', boxShadow: '0 -2px 12px rgba(0,0,0,0.1)', zIndex: 100 }}>
      <div style={{ display: 'flex', alignItems: 'center', gap: 16 }}>
        <svg width="60" height="60" style={{ transform: 'rotate(-90deg)' }}>
          <circle cx="30" cy="30" r={radius * 0.9} fill="none" stroke="#eee" strokeWidth="5" />
          <circle cx="30" cy="30" r={radius * 0.9} fill="none" stroke={isDone ? '#27ae60' : '#e74c3c'} strokeWidth="5"
            strokeDasharray={`${circumference * 0.9} ${circumference * 0.9}`}
            strokeDashoffset={(circumference * 0.9) * (1 - pct)}
            style={{ transition: 'stroke-dashoffset 1s linear' }} />
        </svg>
        <div>
          <div style={{ fontSize: isDone ? 16 : 28, fontWeight: 700, color: isDone ? '#27ae60' : '#222', fontFamily: 'monospace' }}>
            {isDone ? 'Klaar voor volgende set!' : `${mins}:${String(secs).padStart(2, '0')}`}
          </div>
          {!isDone && <div style={{ fontSize: 12, color: '#888' }}>Rusttijd</div>}
        </div>
      </div>
      <button onClick={onDismiss} style={{ padding: '8px 20px', fontSize: 14, background: isDone ? '#27ae60' : 'transparent', color: isDone ? 'white' : '#666', border: `1px solid ${isDone ? '#27ae60' : '#ccc'}`, borderRadius: 4, cursor: 'pointer', fontWeight: isDone ? 600 : 400 }}>
        {isDone ? 'Doorgaan' : 'Overslaan'}
      </button>
    </div>
  );
}

function SetRow({ set, index, label, onToggle, onWeightChange, isWarmup }) {
  const [editing, setEditing] = useState(false);
  const [inputVal, setInputVal] = useState(String(set.weight));
  const inputRef = useRef(null);
  useEffect(() => { if (editing && inputRef.current) inputRef.current.focus(); }, [editing]);
  function handleEditClick(e) {
    e.stopPropagation();
    setInputVal(String(set.weight));
    setEditing(true);
  }
  function handleConfirm() {
    const val = parseFloat(inputVal);
    if (!isNaN(val) && val > 0) onWeightChange(val);
    setEditing(false);
  }
  function handleKeyDown(e) {
    if (e.key === 'Enter') handleConfirm();
    if (e.key === 'Escape') setEditing(false);
  }
  return (
    <div style={{ display: 'flex', alignItems: 'center', padding: '14px 16px', borderBottom: '1px solid #eee', background: set.done ? '#f0fff4' : isWarmup ? '#fafafa' : 'white' }}>
      <div onClick={onToggle} style={{ width: 28, height: 28, borderRadius: '50%', border: `2px solid ${set.done ? '#27ae60' : isWarmup ? '#bbb' : '#ddd'}`, background: set.done ? '#27ae60' : 'white', display: 'flex', alignItems: 'center', justifyContent: 'center', marginRight: 14, flexShrink: 0, cursor: 'pointer' }}>
        {set.done && <span style={{ color: 'white', fontSize: 14 }}>✓</span>}
      </div>
      <div onClick={onToggle} style={{ flex: 1, cursor: 'pointer' }}>
        <span style={{ fontWeight: 500, color: set.done ? '#888' : isWarmup ? '#999' : '#222', textDecoration: set.done ? 'line-through' : 'none' }}>{label}</span>
        <span style={{ color: '#aaa', fontSize: 13, marginLeft: 8 }}>{set.reps} reps</span>
      </div>
      <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
        {editing ? (
          <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
            <input ref={inputRef} type="number" value={inputVal} onChange={e => setInputVal(e.target.value)} onKeyDown={handleKeyDown}
              style={{ width: 70, padding: '4px 8px', fontSize: 16, fontWeight: 700, borderRadius: 4, border: '2px solid #e74c3c', textAlign: 'right' }} />
            <span style={{ fontSize: 13, color: '#888' }}>kg</span>
            <button onClick={handleConfirm} style={{ padding: '4px 10px', fontSize: 13, background: '#e74c3c', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer' }}>✓</button>
          </div>
        ) : (
          <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
            <span style={{ fontWeight: 700, fontSize: 18, color: set.done ? '#888' : isWarmup ? '#999' : '#222' }}>{set.weight} kg</span>
            {set.pct && <span style={{ color: '#aaa', fontSize: 12 }}>{Math.round(set.pct * 100)}%</span>}
            <button onClick={handleEditClick} style={{ background: 'none', border: 'none', cursor: 'pointer', fontSize: 16, padding: '2px 4px', color: '#aaa', lineHeight: 1 }}>✎</button>
          </div>
        )}
      </div>
    </div>
  );
}

function BodyWeightModal({ onSave, onSkip }) {
  const [weight, setWeight] = useState('');
  return (
    <div style={{ position: 'fixed', top: 0, left: 0, right: 0, bottom: 0, background: 'rgba(0,0,0,0.5)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 200 }}>
      <div style={{ background: 'white', borderRadius: 12, padding: 24, maxWidth: 340, width: '90%' }}>
        <h3 style={{ margin: '0 0 8px' }}>Workout voltooid! 💪</h3>
        <p style={{ color: '#666', fontSize: 14, margin: '0 0 20px' }}>Wil je je lichaamsgewicht invoeren?</p>
        <label style={{ display: 'block', marginBottom: 4, fontWeight: 500, fontSize: 14 }}>Lichaamsgewicht (kg)</label>
        <input type="number" value={weight} onChange={e => setWeight(e.target.value)} placeholder="bijv. 85.5" autoFocus
          style={{ width: '100%', padding: 10, fontSize: 16, borderRadius: 4, border: '1px solid #ccc', boxSizing: 'border-box', marginBottom: 16 }} />
        <div style={{ display: 'flex', gap: 8 }}>
          <button onClick={onSkip} style={{ flex: 1, padding: 10, fontSize: 14, background: 'transparent', border: '1px solid #ccc', borderRadius: 4, cursor: 'pointer', color: '#666' }}>Overslaan</button>
          <button onClick={() => { const v = parseFloat(weight); if (!isNaN(v) && v > 0) onSave(v); else onSkip(); }}
            style={{ flex: 1, padding: 10, fontSize: 14, background: '#e74c3c', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer', fontWeight: 600 }}>Opslaan</button>
        </div>
      </div>
    </div>
  );
}

function NewCycleModal({ prs, onStart }) {
  return (
    <div style={{ position: 'fixed', top: 0, left: 0, right: 0, bottom: 0, background: 'rgba(0,0,0,0.5)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 200 }}>
      <div style={{ background: 'white', borderRadius: 12, padding: 24, maxWidth: 340, width: '90%' }}>
        <div style={{ fontSize: 40, textAlign: 'center', marginBottom: 8 }}>🏆</div>
        <h3 style={{ margin: '0 0 8px', textAlign: 'center' }}>Cyclus voltooid!</h3>
        <p style={{ color: '#666', fontSize: 14, margin: '0 0 20px', textAlign: 'center' }}>Nieuwe gewichten berekend op basis van je beste prestaties.</p>
        <div style={{ background: '#f9f9f9', borderRadius: 8, padding: 12, marginBottom: 20 }}>
          {['Squat', 'Bench', 'Deadlift'].map(lift => (
            <div key={lift} style={{ display: 'flex', justifyContent: 'space-between', padding: '4px 0', fontSize: 14 }}>
              <span style={{ color: '#666' }}>{lift} e1RM</span>
              <span style={{ fontWeight: 700 }}>{prs[lift] || '—'} kg</span>
            </div>
          ))}
        </div>
        <button onClick={onStart} style={{ width: '100%', padding: 14, fontSize: 16, background: '#e74c3c', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer', fontWeight: 600 }}>
          Nieuwe cyclus starten 🚀
        </button>
      </div>
    </div>
  );
}

function CurrentWorkout({ workout, onToggleWarmup, onToggleSet, onToggleAccessorySet, onWeightChange, onAccessoryWeightChange, onComplete, onViewAll, showNewCycle, newCyclePRs, onStartNewCycle }) {
  const [timer, setTimer] = useState(null);
  const [showBodyWeight, setShowBodyWeight] = useState(false);

if (workout.type === 'rest') {
    return (
      <div style={{ maxWidth: 500, margin: '60px auto', padding: 24, fontFamily: 'sans-serif', textAlign: 'center' }}>
        <h1>Kel Powerlifting</h1>
        <div style={{ background: '#f5f5f5', padding: 40, borderRadius: 8 }}>
          <div style={{ fontSize: 48 }}>🎉</div>
          <h2>Deload week</h2>
          <p style={{ color: '#666' }}>Rust en herstel. Je bent klaar voor de volgende cyclus!</p>
        </div>
        <button onClick={onStartNewCycle} style={{ marginTop: 16, width: '100%', padding: 14, fontSize: 16, background: '#e74c3c', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer', fontWeight: 600 }}>
          Nieuwe cyclus starten 🚀
        </button>
        <button onClick={onViewAll} style={{ marginTop: 8, width: '100%', padding: 10, fontSize: 14, background: 'transparent', border: '1px solid #ccc', borderRadius: 4, cursor: 'pointer', color: '#666' }}>
          Bekijk alle workouts
        </button>
      </div>
    );
  }

  const allDone = (workout.sets || []).every(s => s.done) && (workout.accessories || []).every(a => (a.done || []).every(d => d));
  const headerBg = workout.type === 'peak' ? HEADER_COLOR.peak : HEADER_COLOR[workout.cycle];

  function handleToggle(fn, reps) {
    setTimer(getRestTime(reps));
    fn();
  }

  function handleComplete() {
    setShowBodyWeight(true);
  }

  function handleBodyWeightSave(w) {
    setShowBodyWeight(false);
    onComplete(w);
  }

  function handleBodyWeightSkip() {
    setShowBodyWeight(false);
    onComplete(null);
  }

  return (
    <div style={{ maxWidth: 500, margin: '0 auto', padding: 16, paddingBottom: timer !== null ? 100 : 16, fontFamily: 'sans-serif' }}>
      <div style={{ background: headerBg, color: 'white', padding: '16px 20px', borderRadius: 8, marginBottom: 16, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
        <div>
          <div style={{ fontSize: 13, opacity: 0.75, marginBottom: 2 }}>Workout {workout.number} {workout.cycle ? `— Cyclus ${workout.cycle}` : '— Peak'}</div>
          <div style={{ fontSize: 22, fontWeight: 700 }}>{workout.lift}</div>
        </div>
        <span style={{ background: MODE_COLOR[workout.mode], padding: '4px 12px', borderRadius: 4, fontSize: 13, fontWeight: 500 }}>
          {MODE_LABEL[workout.mode]}
        </span>
      </div>

      {(workout.warmups || []).length > 0 && (
        <div style={{ background: 'white', border: '1px solid #ddd', borderRadius: 8, overflow: 'hidden', marginBottom: 16 }}>
          <div style={{ padding: '10px 16px', background: '#f9f9f9', borderBottom: '1px solid #eee', fontWeight: 500, fontSize: 14, color: '#888' }}>Warming-up</div>
          {workout.warmups.map((w, i) => (
            <SetRow key={i} set={w} index={i} label={`Warm-up ${i + 1}`} isWarmup={true}
              onToggle={() => handleToggle(() => onToggleWarmup(i), w.reps)}
              onWeightChange={val => onWeightChange('warmup', i, val)} />
          ))}
        </div>
      )}

      <div style={{ background: 'white', border: '1px solid #ddd', borderRadius: 8, overflow: 'hidden', marginBottom: 16 }}>
        <div style={{ padding: '10px 16px', background: '#f9f9f9', borderBottom: '1px solid #eee', fontWeight: 500, fontSize: 14 }}>Hoofdsets</div>
        {workout.sets.map((set, i) => (
          <SetRow key={i} set={set} index={i} label={set.label || `Set ${i + 1}`} isWarmup={false}
            onToggle={() => handleToggle(() => onToggleSet(i), set.reps)}
            onWeightChange={val => onWeightChange('set', i, val)} />
        ))}
      </div>

      {(workout.accessories || []).length > 0 && (
        <div style={{ background: 'white', border: '1px solid #ddd', borderRadius: 8, overflow: 'hidden', marginBottom: 16 }}>
          <div style={{ padding: '10px 16px', background: '#f9f9f9', borderBottom: '1px solid #eee', fontWeight: 500, fontSize: 14 }}>Accessoires</div>
          {workout.accessories.map((acc, ai) => (
            <div key={ai}>
              <div style={{ padding: '8px 16px', background: '#fdfdfd', borderBottom: '1px solid #f0f0f0' }}>
                <span style={{ fontWeight: 500, fontSize: 14 }}>{acc.name}</span>
              </div>
              {acc.done.map((done, si) => (
                <SetRow key={si}
                  set={{ done, weight: acc.weights[si], reps: acc.reps }}
                  index={si} label={`Set ${si + 1}`} isWarmup={false}
                  onToggle={() => handleToggle(() => onToggleAccessorySet(ai, si), acc.reps)}
                  onWeightChange={val => onAccessoryWeightChange(ai, si, val)} />
              ))}
            </div>
          ))}
        </div>
      )}

      <button onClick={handleComplete} disabled={!allDone} style={{ width: '100%', padding: 14, fontSize: 16, fontWeight: 600, background: allDone ? '#27ae60' : '#ccc', color: 'white', border: 'none', borderRadius: 4, cursor: allDone ? 'pointer' : 'not-allowed', marginBottom: 10 }}>
        {allDone ? 'Workout voltooien ✓' : 'Vink alle sets af om te voltooien'}
      </button>
      <button onClick={onViewAll} style={{ width: '100%', padding: 10, fontSize: 14, background: 'transparent', border: '1px solid #ccc', borderRadius: 4, cursor: 'pointer', color: '#666' }}>
        Bekijk alle workouts
      </button>

      {timer !== null && <RestTimer key={timer} seconds={timer} onDismiss={() => setTimer(null)} />}
      {showBodyWeight && <BodyWeightModal onSave={handleBodyWeightSave} onSkip={handleBodyWeightSkip} />}
    </div>
  );
}

function StatsScreen({ history, onBack }) {
  const [activeTab, setActiveTab] = useState('lifts');
  const liftData = {};
  const totalData = [];
  const bodyData = [];

  history.forEach(entry => {
    const label = `W${entry.workoutNumber}`;
    if (entry.lift && ['Squat', 'Bench', 'Deadlift'].includes(entry.lift)) {
      if (!liftData[entry.lift]) liftData[entry.lift] = [];
      liftData[entry.lift].push({ label, gewicht: entry.topWeight, e1rm: entry.e1rm });
    }
    if (entry.bodyWeight) bodyData.push({ label, gewicht: entry.bodyWeight });
  });

  const bestPerLift = {};
  history.forEach(entry => {
    if (!entry.lift || !['Squat', 'Bench', 'Deadlift'].includes(entry.lift)) return;
    if (!bestPerLift[entry.lift] || entry.e1rm > bestPerLift[entry.lift].e1rm) {
      bestPerLift[entry.lift] = { topWeight: entry.topWeight, e1rm: entry.e1rm };
    }
    if (bestPerLift.Squat && bestPerLift.Bench && bestPerLift.Deadlift) {
      totalData.push({
        label: `W${entry.workoutNumber}`,
        totaal: bestPerLift.Squat.topWeight + bestPerLift.Bench.topWeight + bestPerLift.Deadlift.topWeight,
        e1rm: bestPerLift.Squat.e1rm + bestPerLift.Bench.e1rm + bestPerLift.Deadlift.e1rm,
      });
    }
  });

  const COLORS = { Squat: '#e74c3c', Bench: '#2980b9', Deadlift: '#27ae60' };

  function renderChart(data, dataKeys, colors, yLabel) {
    if (!data || data.length === 0) return <p style={{ color: '#888', textAlign: 'center', padding: 20 }}>Nog geen data — voltooi workouts om grafieken te zien.</p>;
    return (
      <ResponsiveContainer width="100%" height={220}>
        <LineChart data={data} margin={{ top: 5, right: 10, left: -10, bottom: 5 }}>
          <CartesianGrid strokeDasharray="3 3" stroke="#f0f0f0" />
          <XAxis dataKey="label" tick={{ fontSize: 11 }} />
          <YAxis tick={{ fontSize: 11 }} />
          <Tooltip />
          <Legend wrapperStyle={{ fontSize: 12 }} />
          {dataKeys.map((key, i) => (
            <Line key={key} type="monotone" dataKey={key} stroke={colors[i]} strokeWidth={2} dot={{ r: 3 }} name={key} />
          ))}
        </LineChart>
      </ResponsiveContainer>
    );
  }

  return (
    <div style={{ maxWidth: 500, margin: '0 auto', padding: 16, fontFamily: 'sans-serif' }}>
      <div style={{ display: 'flex', alignItems: 'center', marginBottom: 20 }}>
        <button onClick={onBack} style={{ background: 'none', border: 'none', fontSize: 20, cursor: 'pointer', marginRight: 12, padding: 0 }}>←</button>
        <h2 style={{ margin: 0 }}>Statistieken</h2>
      </div>
      <div style={{ display: 'flex', gap: 8, marginBottom: 20 }}>
        {['lifts', 'totaal', 'lichaam'].map(tab => (
          <button key={tab} onClick={() => setActiveTab(tab)} style={{ flex: 1, padding: '8px 0', fontSize: 13, background: activeTab === tab ? '#e74c3c' : 'transparent', color: activeTab === tab ? 'white' : '#666', border: `1px solid ${activeTab === tab ? '#e74c3c' : '#ddd'}`, borderRadius: 4, cursor: 'pointer', fontWeight: activeTab === tab ? 600 : 400 }}>
            {tab === 'lifts' ? 'Lifts' : tab === 'totaal' ? 'Totaal' : 'Lichaam'}
          </button>
        ))}
      </div>
      {activeTab === 'lifts' && (
        <div>
          {['Squat', 'Bench', 'Deadlift'].map(lift => (
            <div key={lift} style={{ background: 'white', border: '1px solid #ddd', borderRadius: 8, padding: 16, marginBottom: 16 }}>
              <h3 style={{ margin: '0 0 12px', color: COLORS[lift] }}>{lift}</h3>
              {renderChart(liftData[lift] || [], ['gewicht', 'e1rm'], ['#333', COLORS[lift]], 'kg')}
            </div>
          ))}
        </div>
      )}
      {activeTab === 'totaal' && (
        <div style={{ background: 'white', border: '1px solid #ddd', borderRadius: 8, padding: 16 }}>
          <h3 style={{ margin: '0 0 12px' }}>Totaal (SBD)</h3>
          {renderChart(totalData, ['totaal', 'e1rm'], ['#2c3e50', '#e74c3c'], 'kg')}
        </div>
      )}
      {activeTab === 'lichaam' && (
        <div style={{ background: 'white', border: '1px solid #ddd', borderRadius: 8, padding: 16 }}>
          <h3 style={{ margin: '0 0 12px' }}>Lichaamsgewicht</h3>
          {renderChart(bodyData, ['gewicht'], ['#8e44ad'], 'kg')}
        </div>
      )}
    </div>
  );
}

function AllWorkouts({ workouts, currentIndex, onSelect, onBack, onStats }) {
  return (
    <div style={{ maxWidth: 500, margin: '0 auto', padding: 16, fontFamily: 'sans-serif' }}>
      <div style={{ display: 'flex', alignItems: 'center', marginBottom: 20 }}>
        <button onClick={onBack} style={{ background: 'none', border: 'none', fontSize: 20, cursor: 'pointer', marginRight: 12, padding: 0 }}>←</button>
        <h2 style={{ margin: 0, flex: 1 }}>Alle workouts</h2>
        <button onClick={onStats} style={{ background: 'none', border: '1px solid #ddd', borderRadius: 4, padding: '6px 12px', fontSize: 13, cursor: 'pointer', color: '#666' }}>
          Statistieken
        </button>
      </div>
      {workouts.map((workout, idx) => {
        const isCurrent = idx === currentIndex;
        const isDone = idx < currentIndex;
        const headerBg = workout.type === 'rest' ? HEADER_COLOR.rest : workout.type === 'peak' ? HEADER_COLOR.peak : HEADER_COLOR[workout.cycle];
        return (
          <div key={workout.number} onClick={() => onSelect(idx)} style={{ display: 'flex', alignItems: 'center', padding: '12px 16px', marginBottom: 8, borderRadius: 8, border: isCurrent ? '2px solid #e74c3c' : '1px solid #ddd', background: isDone ? '#f9f9f9' : 'white', cursor: 'pointer', opacity: isDone ? 0.6 : 1 }}>
            <div style={{ width: 40, height: 40, borderRadius: 8, background: headerBg, display: 'flex', alignItems: 'center', justifyContent: 'center', color: 'white', fontWeight: 700, fontSize: 13, marginRight: 14, flexShrink: 0 }}>
              {workout.number}
            </div>
            <div style={{ flex: 1 }}>
              <div style={{ fontWeight: isCurrent ? 700 : 500, color: isCurrent ? '#e74c3c' : '#222' }}>
                {workout.type === 'rest' ? 'Deload' : workout.lift}
                {isCurrent && <span style={{ fontSize: 11, background: '#e74c3c', color: 'white', padding: '1px 6px', borderRadius: 3, marginLeft: 8 }}>NU</span>}
              </div>
              <div style={{ fontSize: 12, color: '#888', marginTop: 2 }}>
                {workout.type === 'training' && `${MODE_LABEL[workout.mode]} — Cyclus ${workout.cycle}`}
                {workout.type === 'peak' && 'Peak'}
                {workout.type === 'rest' && 'Rust & herstel'}
              </div>
            </div>
            {isDone && <span style={{ color: '#27ae60', fontSize: 18 }}>✓</span>}
          </div>
        );
      })}
    </div>
  );
}

function Onboarding({ onStart }) {
  const [squat, setSquat] = useState('');
  const [bench, setBench] = useState('');
  const [deadlift, setDeadlift] = useState('');
  function handleStart() {
    const s = parseFloat(squat), b = parseFloat(bench), d = parseFloat(deadlift);
    if (!s || !b || !d) { alert('Vul alle 1RM waarden in!'); return; }
    onStart(s, b, d);
  }
  return (
    <div style={{ maxWidth: 500, margin: '60px auto', padding: 24, fontFamily: 'sans-serif' }}>
      <h1 style={{ marginBottom: 4 }}>Kel Powerlifting</h1>
      <p style={{ color: '#666', marginBottom: 32 }}>Cube Method — 34 workouts</p>
      <div style={{ background: '#f5f5f5', padding: 24, borderRadius: 8 }}>
        <h2 style={{ marginTop: 0 }}>Voer je 1RM in (kg)</h2>
        {[['Squat', squat, setSquat], ['Bench Press', bench, setBench], ['Deadlift', deadlift, setDeadlift]].map(([label, val, setter]) => (
          <div key={label} style={{ marginBottom: 16 }}>
            <label style={{ display: 'block', marginBottom: 4, fontWeight: 500 }}>{label}</label>
            <input type="number" value={val} onChange={e => setter(e.target.value)} placeholder="kg"
              style={{ width: '100%', padding: 10, fontSize: 16, borderRadius: 4, border: '1px solid #ccc', boxSizing: 'border-box' }} />
          </div>
        ))}
        <button onClick={handleStart} style={{ width: '100%', padding: 14, fontSize: 16, background: '#e74c3c', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer', marginTop: 8 }}>
          Start programma
        </button>
      </div>
    </div>
  );
}

export default function App() {
  const [screen, setScreen] = useState('onboarding');
  const [workouts, setWorkouts] = useState([]);
  const [currentIndex, setCurrentIndex] = useState(0);
  const [history, setHistory] = useState([]);
  const [prs, setPrs] = useState({});
  const [accessoryPRs, setAccessoryPRs] = useState({});
  const [showNewCycle, setShowNewCycle] = useState(false);

  useEffect(() => {
    const saved = localStorage.getItem('kel-powerlifting');
    if (saved) {
      try {
        const data = JSON.parse(saved);
        if (data.workouts && data.workouts[0] && data.workouts[0].warmups !== undefined) {
          setWorkouts(data.workouts);
          setCurrentIndex(data.currentIndex || 0);
          setScreen(data.screen === 'onboarding' ? 'current' : (data.screen || 'current'));
          setHistory(data.history || []);
          setPrs(data.prs || {});
          setAccessoryPRs(data.accessoryPRs || {});
          setShowNewCycle(data.showNewCycle || false);
        } else {
          localStorage.removeItem('kel-powerlifting');
        }
      } catch(e) {
        localStorage.removeItem('kel-powerlifting');
      }
    }
  }, []);

  useEffect(() => {
    if (workouts.length > 0) {
      localStorage.setItem('kel-powerlifting', JSON.stringify({
        workouts, currentIndex, screen, history, prs, accessoryPRs, showNewCycle
      }));
    }
  }, [workouts, currentIndex, screen, history, prs, accessoryPRs, showNewCycle]);

  function handleStart(s, b, d) {
    setWorkouts(generateProgram(s, b, d, {}));
    setCurrentIndex(0);
    setHistory([]);
    setPrs({ Squat: s, Bench: b, Deadlift: d });
    setAccessoryPRs({});
    setShowNewCycle(false);
    setScreen('current');
  }

  function handleStartNewCycle() {
    const newWorkouts = generateProgram(prs.Squat, prs.Bench, prs.Deadlift, accessoryPRs);
    setWorkouts(newWorkouts);
    setCurrentIndex(0);
    setShowNewCycle(false);
    setScreen('current');
  }

  function toggleWarmup(wIndex) {
    setWorkouts(prev => prev.map((w, wi) => wi !== currentIndex ? w : { ...w, warmups: w.warmups.map((wu, i) => i === wIndex ? { ...wu, done: !wu.done } : wu) }));
  }
  function toggleSet(setIndex) {
    setWorkouts(prev => prev.map((w, wi) => wi !== currentIndex ? w : { ...w, sets: w.sets.map((s, si) => si === setIndex ? { ...s, done: !s.done } : s) }));
  }
  function toggleAccessorySet(accIndex, setIndex) {
    setWorkouts(prev => prev.map((w, wi) => wi !== currentIndex ? w : {
      ...w, accessories: w.accessories.map((a, ai) => ai !== accIndex ? a : {
        ...a, done: a.done.map((d, di) => di === setIndex ? !d : d)
      })
    }));
  }
  function changeWeight(type, index, val) {
    setWorkouts(prev => prev.map((w, wi) => {
      if (wi !== currentIndex) return w;
      if (type === 'warmup') return { ...w, warmups: w.warmups.map((wu, i) => i === index ? { ...wu, weight: val } : wu) };
      if (type === 'set') return { ...w, sets: w.sets.map((s, i) => i === index ? { ...s, weight: val } : s) };
      return w;
    }));
  }
  function changeAccessoryWeight(accIndex, setIndex, val) {
    setWorkouts(prev => prev.map((w, wi) => wi !== currentIndex ? w : {
      ...w, accessories: w.accessories.map((a, ai) => ai !== accIndex ? a : {
        ...a, weights: a.weights.map((wt, i) => i === setIndex ? val : wt)
      })
    }));
  }

  function completeWorkout(bodyWeight) {
    const workout = workouts[currentIndex];

    // Update PRs voor hoofdlifts
    if (workout.type === 'training' && ['Squat', 'Bench', 'Deadlift'].includes(workout.lift)) {
      const topSet = workout.sets.reduce((best, s) => epley(s.weight, s.reps) > epley(best.weight, best.reps) ? s : best, workout.sets[0]);
      const newE1rm = epley(topSet.weight, topSet.reps);

      setPrs(prev => {
        const current = prev[workout.lift] || 0;
        return newE1rm > current ? { ...prev, [workout.lift]: newE1rm } : prev;
      });

      const entry = {
        workoutNumber: workout.number,
        lift: workout.lift,
        topWeight: topSet.weight,
        topReps: topSet.reps,
        e1rm: newE1rm,
        bodyWeight: bodyWeight || null,
        date: new Date().toLocaleDateString('nl-NL'),
      };
      setHistory(prev => [...prev, entry]);
    } else if (bodyWeight) {
      setHistory(prev => [...prev, { workoutNumber: workout.number, lift: null, bodyWeight, date: new Date().toLocaleDateString('nl-NL') }]);
    }

    // Update accessoire PRs
    if (workout.accessories) {
      workout.accessories.forEach(acc => {
        const bestWeight = Math.max(...acc.weights);
        setAccessoryPRs(prev => {
          const current = prev[acc.name] || 0;
          return bestWeight > current ? { ...prev, [acc.name]: bestWeight } : prev;
        });
      });
    }

    // Check of dit de laatste workout is (workout 33 = deload)
    const isLastWorkout = currentIndex === workouts.length - 2;
    if (isLastWorkout) {
      setShowNewCycle(true);
    }

    if (currentIndex < workouts.length - 1) setCurrentIndex(i => i + 1);
    setScreen('current');
  }

  function selectWorkout(idx) {
    setCurrentIndex(idx);
    setScreen('current');
  }

  if (screen === 'onboarding') return <Onboarding onStart={handleStart} />;
  if (screen === 'stats') return <StatsScreen history={history} onBack={() => setScreen('all')} />;
  if (screen === 'all') return <AllWorkouts workouts={workouts} currentIndex={currentIndex} onSelect={selectWorkout} onBack={() => setScreen('current')} onStats={() => setScreen('stats')} />;
  return <CurrentWorkout
    workout={workouts[currentIndex]}
    onToggleWarmup={toggleWarmup}
    onToggleSet={toggleSet}
    onToggleAccessorySet={toggleAccessorySet}
    onWeightChange={changeWeight}
    onAccessoryWeightChange={changeAccessoryWeight}
    onComplete={completeWorkout}
    onViewAll={() => setScreen('all')}
    showNewCycle={showNewCycle}
    newCyclePRs={prs}
    onStartNewCycle={handleStartNewCycle}
  />;
}